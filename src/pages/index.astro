    'Linha Vermelha': 'Red Line',
    'Linha Verde':    'Green Line',
    'Linha Amarela':  'Yellow Line',
    'Linha Azul':     'Blue Line',
};

const lineColors = {
    'Linha Vermelha': '#E6196E',
    'Linha Verde':    '#00A0A5',
    'Linha Amarela':  '#FAB914',
    'Linha Azul':     '#5082C3',
};

const lineDestinations = {
    'Linha Vermelha': ['Aeroporto', 'São Sebastião'],
    'Linha Verde':    ['Telheiras', 'Cais do Sodré'],
    'Linha Amarela':  ['Odivelas', 'Rato'],
    'Linha Azul':     ['Reboleira', 'Santa Apolónia'],
};

function inferLineName(destinationName, fallbackLineName) {
    for (const [lineName, destinations] of Object.entries(lineDestinations)) {
        if (destinations.includes(destinationName)) return lineName;
    }
    return fallbackLineName ?? 'Linha Azul';
}

const i18n = {
    pt: {
        direction: 'Sentido',
        min: 'MIN',
        alerts: (line) => [
            `${line}: Circulação com atrasos. O tempo de espera pode ser superior ao normal.`,
            `${line}: Circulação interrompida devido a causa alheia ao Metro. A reposição poderá ser superior a 15 minutos.`,
            `Linha Amarela: Circulação interrompida entre Cidade Universitária e Rato devido a avaria de comboio.`,
        ],
    },
    en: {
        direction: 'Towards',
        min: 'MIN',
        alerts: (line) => [
            `${line}: Service delays. Waiting times may be longer than usual.`,
