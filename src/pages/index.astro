  "url": "https://metro.lixo.dev/",
  "applicationCategory": "TransportationApplication",
  "operatingSystem": "Web",
  "inLanguage": ["pt-PT", "en"],
  "isAccessibleForFree": true,
  "author": { "@type": "Person", "name": "Hugo Conceição" },
