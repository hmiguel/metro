    renderHallClock();
    const deps = getStationDeps(station);
    renderHall(deps.length ? deps : [{ destination: 'Santa Apolónia', lineName: 'Linha Azul' }]);
    const hsBand = document.getElementById('hs-alert-band');
    if (hsBand) hsBand.classList.toggle('visible', alertActive);
