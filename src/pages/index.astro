<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Ubuntu:wght@400;500;700&display=swap" rel="stylesheet">

<style is:global>
*, *::before, *::after { box-sizing: border-box; }

:root {
    --primary:    #e85d04;
    --primary-lt: #2a1200;
    --primary-md: #6b2900;
    --green:      #00b37a;
    --green-lt:   rgba(0,179,122,.12);
    --red:        #f55a4e;
    --red-lt:     rgba(245,90,78,.12);
    --amber:      #f0c800;
    --amber-lt:   rgba(240,200,0,.12);
    --cyan:       #3a9fd4;
    --bg:         #111009;
    --sel-bg:     #1c1a18;
    --sel-border: rgba(255,255,255,.12);
    --sel-shadow: 3px 3px 0 rgba(232,93,4,.3);
    --text:       #f0ece6;
    --muted:      #969696;
    --label-color: #969696;
    --btn-color:  rgba(240,236,230,.5);
    --btn-border: rgba(255,255,255,.12);
    --btn-hover-bg:     rgba(232,93,4,.1);
    --btn-hover-color:  #e85d04;
    --btn-hover-border: rgba(232,93,4,.65);
    --btn-active-bg:     rgba(232,93,4,.15);
    --btn-active-border: #e85d04;
    --btn-active-color:  #e85d04;
    --input-bg:          #111009;
    --input-color:       rgba(240,236,230,.85);
    --input-placeholder: #969696;
    --input-border:      rgba(255,255,255,.12);
    --input-focus-border: #e85d04;
    --suggestions-bg:     #1c1a18;
    --suggestions-border: rgba(255,255,255,.12);
    --suggestion-color:   rgba(240,236,230,.85);
    --suggestion-hover-bg: rgba(232,93,4,.09);
    --sep-color:  rgba(255,255,255,.12);
    --gh-fill:    #f0ece6;
    --footer-color: #969696;
    --status-color: #969696;
}

[data-theme="light"] {
    --primary:    #e85d04;
    --primary-lt: #fff3eb;
    --primary-md: #fed7aa;
    --green:      #00825a;
    --green-lt:   rgba(0,130,90,.1);
    --red:        #f55a4e;
    --red-lt:     rgba(245,90,78,.1);
    --amber:      #b38600;
    --amber-lt:   rgba(179,134,0,.1);
    --cyan:       #146eaa;
    --bg:         #f5f0e8;
    --sel-bg:     #ffffff;
    --sel-border: #1a1a1a;
    --sel-shadow: 3px 3px 0 #111111;
    --text:       #111111;
    --muted:      #555555;
    --label-color: #555555;
    --btn-color:  #555555;
    --btn-border: #1a1a1a;
    --btn-hover-bg:     rgba(232,93,4,.08);
    --btn-hover-color:  #e85d04;
    --btn-hover-border: #e85d04;
    --btn-active-bg:     rgba(232,93,4,.1);
    --btn-active-border: #e85d04;
    --btn-active-color:  #e85d04;
    --input-bg:          #f5f0e8;
    --input-color:       #111111;
    --input-placeholder: #999999;
    --input-border:      #1a1a1a;
    --input-focus-border: #e85d04;
    --suggestions-bg:     #ffffff;
    --suggestions-border: #1a1a1a;
    --suggestion-color:   #111111;
    --suggestion-hover-bg: rgba(232,93,4,.07);
    --sep-color:   #1a1a1a;
    --gh-fill:     #111111;
    --footer-color: #555555;
    --status-color: #555555;
}

html {
    background: var(--bg);
    transition: background .3s;
}

body {
    margin: 0 auto;
    padding: 32px 48px 48px;
    background: var(--bg);
    transition: background .3s;
    width: 100%;
    max-width: 1400px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
    font-family: "Ubuntu", sans-serif;
}

/* ── Selector card ───────────── */
.selector {
    display: flex;
    flex-direction: column;
    align-self: flex-start;
    background: var(--sel-bg);
    border: 2px solid var(--sel-border);
    box-shadow: var(--sel-shadow);
    transition: background .25s, border-color .25s, box-shadow .25s;
}

/* ── Page heading (outside any card) ── */
.heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--sel-border);
    transition: border-color .25s;
}

.page-title {
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -.01em;
    color: var(--text);
    user-select: none;
    margin: 0;
    transition: color .25s;
}

.heading-actions {
    display: flex;
    align-items: center;
    gap: 6px;
}

.sel-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    padding: 10px 16px;
    border-bottom: 2px solid var(--sel-border);
    transition: border-color .25s;
}

.sel-row:last-child,
.sel-section-head ~ .sel-row {
    border-bottom: none;
}

.sel-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--label-color);
    width: 110px;
    flex-shrink: 0;
    user-select: none;
    transition: color .25s;
}

.sel-status {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: var(--status-color);
    transition: color .25s;
}

.sel-controls {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}

.sel-controls > * {
    flex-shrink: 0;
}

/* ── Base button ─────────────── */
.selector button,
.heading button,
.context-preview-btn-wrap button {
    background: transparent;
    border: 2px solid var(--btn-border);
    color: var(--btn-color);
    font-family: "Ubuntu", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .07em;
    text-transform: uppercase;
    padding: 7px 16px;
    cursor: pointer;
    transition: background .1s, color .1s, border-color .1s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    line-height: 1;
}

.selector button:hover,
.heading button:hover,
.context-preview-btn-wrap button:hover {
    background: var(--btn-hover-bg);
    border-color: var(--btn-hover-border);
    color: var(--btn-hover-color);
}

.selector button.active,
.heading button.active,
.context-preview-btn-wrap button.active {
    background: var(--btn-active-bg);
    border-color: var(--btn-active-border);
    color: var(--btn-active-color);
}

/* ── Segmented group ─────────── */
.seg-group {
    display: inline-flex;
    flex-shrink: 0;
}

.seg-group button {
    border: 2px solid var(--btn-border);
    padding: 7px 14px;
    position: relative;
    z-index: 0;
}

.seg-group button + button {
    margin-left: -2px;
}

.seg-group button:hover {
    border-color: var(--btn-hover-border);
    color: var(--btn-hover-color);
    z-index: 1;
}

.seg-group button.active {
    background: var(--btn-active-bg);
    color: var(--btn-active-color);
    border-color: var(--btn-active-border);
    z-index: 1;
}

#btn-layout-right,
#btn-layout-left {
    min-width: 78px;
    justify-content: center;
}


/* ── Icon-only buttons ───────── */
.selector button.icon-btn {
    padding: 7px 11px;
    font-size: 12px;
    letter-spacing: 0;
    text-transform: none;
}

.heading button.icon-btn {
    padding: 7px 11px;
    font-size: 15px;
    letter-spacing: 0;
    text-transform: none;
}

/* ── Live button + indicator badge ── */
.selector button.live-btn,
.heading button.live-btn {
    position: relative;
}

.live-indicator {
    display: none;
    position: absolute;
    top: -3px;
    right: -3px;
    width: 6px;
    height: 6px;
    background: var(--primary);
    border: 1.5px solid var(--sel-bg);
    pointer-events: none;
}

.selector button.live-btn.active .live-indicator {
    display: block;
    animation: live-blink 1s ease-in-out infinite;
}

/* ── Section head ────────────── */
.sel-section-head {
    padding: 10px 16px;
    border-bottom: 2px solid var(--sel-border);
    transition: border-color .25s;
}

.sel-section-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--label-color);
    user-select: none;
    transition: color .25s;
}

/* ── Inline secondary label ───── */
.sel-label-inline {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--label-color);
    user-select: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color .25s;
}

/* ── Panel select ────────────── */
.panel-select {
    background: var(--input-bg);
    border: 2px solid var(--input-border);
    color: var(--input-color);
    font-family: "Ubuntu", sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: .02em;
    padding: 7px 11px;
    cursor: pointer;
    outline: none;
    transition: border-color .1s, background .25s, color .25s;
}

.panel-select:focus {
    border-color: var(--input-focus-border);
}

.panel-select option {
    background: var(--suggestions-bg);
    color: var(--suggestion-color);
}


@keyframes live-blink {
    0%, 100% {
        opacity: 1;
        box-shadow: 0 0 0 0 rgba(232,93,4,.6);
    }
    50% {
        opacity: .3;
        box-shadow: 0 0 0 5px rgba(232,93,4,0);
    }
}

/* ── Station search ──────────── */
.station-search-wrap {
    position: relative;
}

.station-search {
    background: var(--input-bg);
    border: 2px solid var(--input-border);
    color: var(--input-color);
    font-family: "Ubuntu", sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: .02em;
    line-height: 1;
    padding: 7px 11px;
    min-width: 150px;
    width: min(220px, 44vw);
    outline: none;
    transition: border-color .1s, background .1s, color .25s;
}

.station-search:focus {
    border-color: var(--input-focus-border);
}

.station-search::placeholder {
    color: var(--input-placeholder);
}

.station-suggestions {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    z-index: 20;
    background: var(--suggestions-bg);
    border: 2px solid var(--suggestions-border);
    max-height: 220px;
    overflow-y: auto;
    box-shadow: var(--sel-shadow);
}

.station-suggestions.hidden {
    display: none;
}

.station-suggestion {
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    color: var(--suggestion-color);
    font-family: "Ubuntu", sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    padding: 8px 12px;
    cursor: pointer;
    display: block;
    transition: background .1s, color .1s;
}

.station-suggestion:hover {
    background: var(--suggestion-hover-bg);
    color: var(--primary);
}

/* ── Station row groups ──────── */
.station-group {
    display: flex;
    align-items: center;
    gap: 8px;
}

/* ── Destination row (select + random btn) ── */
.dest-row {
    display: flex;
    align-items: stretch;
    gap: 8px;
}
.dest-row .destination-select {
    flex: 1;
}
.dest-row .icon-btn {
    align-self: stretch;
    display: flex;
    align-items: center;
}

/* ── Destination select ──────── */
.destination-select {
    background: var(--input-bg);
    border: 2px solid var(--input-border);
    color: var(--input-color);
    font-family: "Ubuntu", sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: .02em;
    line-height: 1;
    padding: 7px 11px;
    cursor: pointer;
    min-width: 120px;
    outline: none;
    transition: border-color .1s, background .25s, color .25s;
}


.destination-select option {
    background: var(--suggestions-bg);
    color: var(--suggestion-color);
}

/* ── GitHub link ─────────────── */
.gh-link {
    display: flex;
    align-items: center;
    opacity: .35;
    transition: opacity .1s;
    padding: 4px;
}

.gh-link:hover {
    opacity: .8;
}

.gh-link svg {
    fill: var(--gh-fill);
    transition: fill .25s;
}

/* ── Selector column (station + options stacked) ── */
.selector-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
}

/* ── Controls row (about + selector side by side) ── */
.controls-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 32px;
}

/* ── About block ─────────────── */
.about-block {
    display: flex;
    flex-direction: column;
    align-self: stretch;
    background: var(--sel-bg);
    border: 2px solid var(--sel-border);
    box-shadow: var(--sel-shadow);
    transition: background .25s, border-color .25s, box-shadow .25s;
    padding: 16px;
    gap: 14px;
    width: 360px;
    flex-shrink: 0;
    justify-content: center;
}
.about-block p {
    margin: 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--muted);
    transition: color .25s;
}
.about-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(150,150,150,.4);
    transition: color .15s, text-decoration-color .15s;
}
.about-link:hover {
    color: var(--text);
    text-decoration-color: var(--primary);
}

/* ── Footer ──────────────────── */
.footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .5rem;
    color: var(--footer-color);
    font-size: .72rem;
    font-weight: 400;
    padding: 1.75rem 0 .5rem;
    margin-top: auto;
    text-align: center;
    transition: color .25s;
    width: 100%;
}
.footer-gh {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    color: var(--footer-color);
    text-decoration: none;
    font-weight: 400;
    transition: color .1s;
}
.footer-gh:hover { color: var(--primary); }
.footer-gh svg { flex-shrink: 0; }
.build-sha {
    font-size: 11px;
    font-weight: 400;
    text-decoration: none;
    color: var(--footer-color);
    opacity: .5;
    font-variant-numeric: tabular-nums;
    transition: color .2s, opacity .2s;
}
.build-sha:hover { color: var(--primary); opacity: 1; }

@media (max-width: 600px) {
    body {
        padding: 16px 16px 32px;
        gap: 16px;
    }
    .controls-row {
        flex-direction: column;
        align-self: stretch;
    }
    .about-block {
        width: 100%;
        align-self: stretch;
        justify-content: flex-start;
    }
    .selector-col {
        align-self: stretch;
    }
    .selector {
        align-self: stretch;
    }
    .sel-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
    }
    .sel-label {
        min-width: 0;
    }
    .selector button {
        padding: 6px 12px;
        font-size: 11px;
    }
    .seg-group button {
        padding: 6px 10px;
    }
    .station-search {
        width: 100%;
        min-width: 0;
    }
    .station-search-wrap {
        width: 100%;
    }
    .dest-row {
        width: 100%;
    }
    .dest-row .destination-select {
        flex: 1;
        min-width: 0;
    }
}

/* ── Panel physical frame ────── */
.panel-frame {
    position: relative;
    align-self: flex-start;
    padding: 16px 16px 22px;
    background: #1c1a18;
    border: 2px solid var(--sel-border);
    box-shadow: var(--sel-shadow);
    transition: border-color .25s, box-shadow .25s;
}

/* ── Preview area ────────────── */
.preview-item {
    display: none;
    flex-direction: column;
    gap: 8px;
    max-width: 100%;
    overflow: visible;
    padding-bottom: 6px;
    padding-right: 6px;
}

.preview-item.visible {
    display: flex;
}

.preview-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: .1em;
    text-transform: uppercase;
    transition: color .25s;
}

/* ── Panel ───────────────────── */
.panel {
    --s: 1;
    --line-color: #5082C3;
    background: #00114a;
    color: white;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    padding: calc(var(--s) * 22px) calc(var(--s) * 40px) calc(var(--s) * 18px);
    position: relative;
}

.line-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: calc(var(--s) * 6px);
    background: var(--line-color);
}

/* 0.65 px/mm */
.tipo-a { width: 1570px; height: 432px; --s: 1.199; }
.tipo-b { width: 1625px; height: 364px; --s: 1.011; }
.tipo-c { width: 1570px; height: 345px; --s: 0.957; }
.tipo-d { width:  923px; height: 254px; --s: 0.705; }

/* ── Header ─────────────────── */
.top {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.label {
    display: block;
    font-size: calc(var(--s) * 19px);
    font-weight: 700;
    letter-spacing: .05em;
    white-space: nowrap;
    text-transform: uppercase;
}

.clock {
    font-size: calc(var(--s) * 44px);
    font-weight: 700;
}

/* ── Train rows ─────────────── */
.trains {
    display: flex;
    flex-direction: column;
    flex: 1;
}

.row-next-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
}

.row-next {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    width: 100%;
    padding-bottom: calc(var(--s) * 8px);
}

body.layout-reversed .row-next {
    flex-direction: row-reverse;
}

.next-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: flex-start;
    flex: 0 0 calc(var(--s) * 150px);
    width: calc(var(--s) * 150px);
    min-width: calc(var(--s) * 150px);
    margin-left: auto;
    padding-bottom: calc(var(--s) * 22px);
    padding-right: calc(var(--s) * 30px);
}

body.layout-reversed .next-meta {
    align-items: flex-start;
    justify-content: flex-end;
    margin-left: 0;
    margin-right: auto;
    padding-right: 0;
    padding-left: calc(var(--s) * 30px);
}

.capacity-heads {
    display: flex;
    align-items: center;
    gap: calc(var(--s) * 4px);
}

.capacity-carriage {
    position: relative;
    height: calc(var(--s) * 32px);
    aspect-ratio: 5 / 2;
    border: calc(var(--s) * 2px) solid rgba(255,255,255,0.28);
    border-radius: calc(var(--s) * 4px);
    overflow: hidden;
    background: rgba(255,255,255,0.05);
}

.capacity-carriage::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    transition: height 0.5s ease;
}

.capacity-carriage.empty::after { height: 20%; background: #00A0A5; } /* Linha Verde  */
.capacity-carriage.half::after  { height: 55%; background: #FAB914; } /* Linha Amarela */
.capacity-carriage.full::after  { height: 90%; background: #E6196E; } /* Linha Vermelha */

.capacity-heads::before,
.capacity-heads::after {
    content: '';
    flex-shrink: 0;
    align-self: center;
    width: calc(var(--s) * 12px);
    height: calc(var(--s) * 12px);
}

/* Normal layout: chevron points right (after carriages) */
.capacity-heads::before { display: none; }
.capacity-heads::after {
    border-top: calc(var(--s) * 2px) solid rgba(255,255,255,0.5);
    border-right: calc(var(--s) * 2px) solid rgba(255,255,255,0.5);
    transform: rotate(45deg);
}

/* Reversed layout: chevron points left (before carriages) */
body.layout-reversed .capacity-heads::before {
    display: block;
    border-top: calc(var(--s) * 2px) solid rgba(255,255,255,0.5);
    border-left: calc(var(--s) * 2px) solid rgba(255,255,255,0.5);
    transform: rotate(-45deg);
}
body.layout-reversed .capacity-heads::after { display: none; }

.time-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: calc(var(--s) * 92px);
    text-align: center;
    line-height: 1;
}

.time-value {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: calc(var(--s) * 2px);
    width: 100%;
    font-size: calc(var(--s) * 130px);
    font-weight: 700;
    line-height: 1;
    text-align: center;
    font-variant-numeric: tabular-nums;
}

.time-value .wait-seconds {
    font-size: .26em;
    line-height: 1;
    margin-top: .36em;
}


.time-block.blink {
    animation: blink 2s ease-in-out infinite;
}

.minute-change-blink {
    animation: minute-change-blink 450ms ease-in-out;
}

@keyframes minute-change-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: .2; }
}

@keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.15; }
}
.time-unit {
    font-size: calc(var(--s) * 20px);
    font-weight: 700;
    line-height: 1;
    margin-top: calc(var(--s) * 1px);
}

.destination {
    font-size: calc(var(--s) * 130px);
    font-weight: 700;
    line-height: 1;
    flex: 1 1 auto;
    min-width: 0;
    align-self: flex-start;
}

body.layout-reversed .destination {
    text-align: right;
}

.divider {
    height: 1px;
    background: rgba(255,255,255,.5);
    margin: calc(var(--s) * 8px) 0 calc(var(--s) * 10px);
}

body.layout-reversed .divider {
    align-self: flex-end;
}

.row-next-wrap .capacity-heads {
    align-self: flex-start;
}

body.layout-reversed .row-next-wrap .capacity-heads {
    align-self: flex-end;
}

.row-after {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    margin-top: auto;
}

body.layout-reversed .row-after {
    flex-direction: row-reverse;
}

.after-group {
    display: flex;
    align-items: baseline;
    gap: calc(var(--s) * 32px);
    flex-shrink: 0;
    margin-left: auto;
    padding-left: calc(var(--s) * 20px);
}

body.layout-reversed .after-group {
    margin-left: 0;
    margin-right: auto;
    padding-left: 0;
    padding-right: calc(var(--s) * 20px);
}

.after-times {
    display: flex;
    align-items: flex-end;
    gap: calc(var(--s) * 32px);
}

.after-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
}

.after-value {
    font-size: calc(var(--s) * 50px);
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
}

.after-unit {
    font-size: calc(var(--s) * 13px);
    font-weight: 700;
    margin-top: calc(var(--s) * 1px);
}

.after-block:last-child {
    opacity: .8;
}

/* ── Alert (inside row-after, left side) */
.alert-strip {
    display: none;
    align-items: stretch;
    background: white;
    flex: 1;
    margin-right: calc(var(--s) * 20px);
    overflow: hidden;
    border-radius: calc(var(--s) * 6px);
}

body.layout-reversed .alert-strip {
    margin-right: 0;
    margin-left: calc(var(--s) * 20px);
}

.alert-strip.visible {
    display: flex;
}

.alert-bar {
    width: calc(var(--s) * 8px);
    background: #ffb400;
    flex-shrink: 0;
    border-radius: calc(var(--s) * 6px) 0 0 calc(var(--s) * 6px);
    position: relative;
    z-index: 2;
}

.alert-text {
    font-size: calc(var(--s) * 27px);
    font-weight: 500;
    color: #00114a;
    line-height: 1.25;
    padding: 0 calc(var(--s) * 14px);
    display: flex;
    align-items: center;
    white-space: nowrap;
    position: relative;
    z-index: 1;
}

.capacity-hidden .capacity-heads { display: none; }
.capacity-hidden .destination { font-size: calc(var(--s) * 142px); }
.capacity-hidden .time-value { font-size: calc(var(--s) * 142px); }
.capacity-hidden .time-block { width: calc(var(--s) * 100px); min-width: calc(var(--s) * 100px); }

@keyframes marquee {
    0%   { transform: translateX(var(--marquee-from)); }
    100% { transform: translateX(var(--marquee-to)); }
}

/* ── Context / In-situ View ──────────────────────────────── */
.context-inline {
    display: none;
    margin-top: 12px;
}
.context-inline.visible { display: block; }
.context-scene {
    position: relative;
    width: min(1600px, 95vw);
    overflow: hidden;
    border-radius: 6px;
}
.context-bg {
    width: 100%;
    display: block;
    pointer-events: none;
}
.context-panel-slot {
    position: absolute;
    top: 13%;
    left: 31%;
    width: 38%;
    filter: drop-shadow(0 4px 16px rgba(0,0,0,.65));
    cursor: grab;
    user-select: none;
}
.context-panel-slot.dragging { cursor: grabbing; }
.context-panel-slot::before,
.context-panel-slot::after {
    content: '';
    position: absolute;
    bottom: 100%;
    width: 4px;
    height: 500px;
    background: linear-gradient(to bottom, rgba(20,20,20,0) 0%, rgba(20,20,20,.85) 100%);
    border-radius: 2px;
}
.context-panel-slot::before { left: 22%; transform: translateX(-50%); }
.context-panel-slot::after  { left: 78%; transform: translateX(-50%); }
.context-preview-btn-wrap {
    display: flex;
    margin-top: 10px;
}
body.hall-mode .context-preview-btn-wrap { display: none; }
.context-expand-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(0,0,0,.45);
    border: none;
    color: rgba(255,255,255,.8);
    cursor: pointer;
    padding: 6px;
    line-height: 0;
    border-radius: 4px;
    transition: background .15s, color .15s;
    z-index: 10;
}
.context-expand-btn:hover { background: rgba(0,0,0,.7); color: #fff; }
.context-scene.expanded {
    position: fixed;
    inset: 0;
    width: 100vw;
    max-width: none;
    border-radius: 0;
    z-index: 150;
}
.context-scene.expanded .context-bg { height: 100vh; object-fit: cover; }

/* ── Hall Screen ─────────────────────────────────────────── */
body.hall-mode #row-orientation,
body.hall-mode #row-capacity,
body.hall-mode #group-dest { display: none; }
.hs-screen { width:1920px; height:1080px; background:#00114a; color:#fff; display:flex; flex-direction:column; overflow:hidden; position:relative; font-family:'Ubuntu',sans-serif; }
