.capacity-head.filled {
    background: white;
}

.time-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: calc(var(--s) * 92px);
    text-align: center;
    line-height: 1;
}

.time-value {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: calc(var(--s) * 2px);
    width: 100%;
    font-size: calc(var(--s) * 130px);
    font-weight: 700;
    line-height: 1;
    text-align: center;
    font-variant-numeric: tabular-nums;
}

.time-value .wait-seconds {
    font-size: .26em;
    line-height: 1;
    margin-top: .36em;
}


.time-block.blink {
    animation: blink 2s ease-in-out infinite;
}

.minute-change-blink {
    animation: minute-change-blink 450ms ease-in-out;
}

@keyframes minute-change-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: .2; }
}

@keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.15; }
}
.time-unit {
    font-size: calc(var(--s) * 20px);
    font-weight: 700;
    line-height: 1;
    margin-top: calc(var(--s) * 1px);
}

.destination {
    font-size: calc(var(--s) * 130px);
    font-weight: 700;
    line-height: 1;
    flex: 1 1 auto;
    min-width: 0;
    align-self: flex-start;
}

body.layout-reversed .destination {
    text-align: right;
}

.divider {
    height: 1px;
    background: rgba(255,255,255,.5);
    margin: calc(var(--s) * 11px) 0 calc(var(--s) * 10px);
}

.row-after {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
}

body.layout-reversed .row-after {
    flex-direction: row-reverse;
}

.after-group {
    display: flex;
    align-items: baseline;
    gap: calc(var(--s) * 32px);
    flex-shrink: 0;
    margin-left: auto;
    padding-left: 15px;
}

body.layout-reversed .after-group {
    margin-left: 0;
    margin-right: auto;
    padding-left: 0;
    padding-right: 15px;
}

.after-times {
    display: flex;
    align-items: flex-end;
    gap: calc(var(--s) * 32px);
}

.after-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
}

.after-value {
    font-size: calc(var(--s) * 50px);
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
}

.after-unit {
    font-size: calc(var(--s) * 13px);
    font-weight: 700;
    margin-top: calc(var(--s) * 1px);
}

.after-block:last-child {
    opacity: .8;
}

/* ── Alert (inside row-after, left side) */
.alert-strip {
    display: none;
    align-items: stretch;
    background: white;
    flex: 1;
    margin-right: calc(var(--s) * 20px);
    overflow: hidden;
    border-radius: calc(var(--s) * 6px);
}

body.layout-reversed .alert-strip {
    margin-right: 0;
    margin-left: calc(var(--s) * 20px);
}

.alert-strip.visible {
    display: flex;
}

.alert-bar {
    width: calc(var(--s) * 8px);
    background: #ffb400;
    flex-shrink: 0;
    border-radius: calc(var(--s) * 6px) 0 0 calc(var(--s) * 6px);
    position: relative;
    z-index: 2;
}

.alert-text {
    font-size: calc(var(--s) * 27px);
    font-weight: 500;
    color: #00114a;
    line-height: 1.25;
    padding: 0 calc(var(--s) * 14px);
    display: flex;
    align-items: center;
    white-space: nowrap;
    position: relative;
    z-index: 1;
}

@keyframes marquee {
    0%   { transform: translateX(var(--marquee-from)); }
    100% { transform: translateX(var(--marquee-to)); }
}
</style>
</head>

