<script is:inline define:vars={{ stops }}>
let alertActive = false;
let capacityVisible = true;
let currentLang = 'pt';
let layoutReversed = false;
let currentPanelType = 'a';
let liveMode = false;
let currentTheme = 'light';
let currentState = {};
let liveIntervalId = null;
let liveStation = null;
let liveDestination = null;
let liveArrivals = [];
let lastNextTrainKey = null;
const LIVE_API_BASE = 'https://4belhato.trade/api/metro/arrivals/';
const STOPS = stops;

const PANEL_SIZES = {
    a:    {w:1570, h:432,  s:1.199},
    b:    {w:1625, h:364,  s:1.011},
    c:    {w:1570, h:345,  s:0.957},
    d:    {w:923,  h:254,  s:0.705},
    hall: {w:1920, h:1080, s:1},
};

function scaleToFit() {
    const bodyStyles = getComputedStyle(document.body);
    const bodyPadding =
        parseFloat(bodyStyles.paddingLeft) + parseFloat(bodyStyles.paddingRight);
    const available = Math.max(0, document.documentElement.clientWidth - bodyPadding);
    let activeWidth = null;
    ['a','b','c','d','hall'].forEach(t => {
        const preview = document.getElementById('preview-' + t);
        const frame   = preview && preview.querySelector('.panel-frame');
        if (!frame) return;
        const {w, h} = PANEL_SIZES[t];
        const fw = w + 32, fh = h + 38; // frame: 16px×2 h-pad, 16+22 v-pad
        if (available < fw) {
            const scale = available / fw;
            frame.style.transform       = `scale(${scale})`;
            frame.style.transformOrigin = 'top left';
            frame.style.marginRight     = `${-Math.round(fw  * (1 - scale))}px`;
            frame.style.marginBottom    = `${-Math.round(fh  * (1 - scale))}px`;
            preview.style.width    = Math.floor(available) + 'px';
            preview.style.height   = Math.round(fh * scale) + 21 + 'px';
            preview.style.overflow = 'hidden';
            if (preview.classList.contains('visible')) activeWidth = Math.floor(available) + 'px';
        } else {
            frame.style.transform       = '';
            frame.style.transformOrigin = '';
            frame.style.marginRight     = '';
            frame.style.marginBottom    = '';
            preview.style.width    = '';
            preview.style.height   = '';
            preview.style.overflow = '';
            if (preview.classList.contains('visible')) activeWidth = fw + 'px';
        }
    });
    const heading = document.querySelector('.heading');
    if (heading && activeWidth) heading.style.width = activeWidth;
}

function selectType(type) {
    if (!['a','b','c','d','hall'].includes(type)) return;
    currentPanelType = type;
    ['a','b','c','d','hall'].forEach(t => {
        document.getElementById('preview-' + t).classList.toggle('visible', t === type);
    });
    const sel = document.getElementById('panel-select');
    if (sel) sel.value = type;
    document.body.classList.toggle('hall-mode', type === 'hall');
    scaleToFit();
    if (type === 'hall') renderHallScreen();
    if (alertActive && type !== 'hall') requestAnimationFrame(updateAlertScroll);
}

function setCapacity(visible) {
    capacityVisible = visible;
    document.getElementById('btn-capacity-on').classList.toggle('active', visible);
    document.getElementById('btn-capacity-off').classList.toggle('active', !visible);
    document.body.classList.toggle('capacity-hidden', !visible);
}

function setAlert(active) {
    alertActive = active;
    document.getElementById('btn-alert-on').classList.toggle('active', active);
    document.getElementById('btn-alert-off').classList.toggle('active', !active);
    document.querySelectorAll('.alert-strip').forEach(el => el.classList.toggle('visible', active));
    const hsBand = document.getElementById('hs-alert-band');
    if (hsBand) hsBand.classList.toggle('visible', active);
    if (active) {
        const t = i18n[currentLang];
        const hsText = document.getElementById('hs-alert-text');
        if (hsText) {
            const stLine = liveStation?.lines?.[0]?.name ?? (currentState.lineName ?? 'Linha Azul');
            hsText.textContent = t.alerts(stLine)[currentState.alertIndex ?? 0] ?? '';
        }
    }
    const cycleBtn = document.getElementById('btn-alert-cycle');
    if (cycleBtn) cycleBtn.style.display = active ? '' : 'none';
    if (active && currentPanelType !== 'hall') requestAnimationFrame(updateAlertScroll);
}

function setLang(lang) {
    currentLang = lang;
    document.getElementById('btn-lang-pt').classList.toggle('active', lang === 'pt');
    document.getElementById('btn-lang-en').classList.toggle('active', lang === 'en');
    document.documentElement.lang = lang === 'en' ? 'en' : 'pt';
    render();
    if (currentPanelType !== 'hall') requestAnimationFrame(updateAlertScroll);
    renderPage();
    if (currentPanelType === 'hall') renderHallScreen();
}

function setLayout(reversed) {
    layoutReversed = reversed;
    document.body.classList.toggle('layout-reversed', reversed);
    document.getElementById('btn-layout-right').classList.toggle('active', !reversed);
    document.getElementById('btn-layout-left').classList.toggle('active', reversed);
    if (alertActive) requestAnimationFrame(updateAlertScroll);
}

function toggleAlert() { setAlert(!alertActive); }

function cycleAlertMessage() {
    if (typeof currentState.alertIndex === 'undefined') return;
    currentState.alertIndex = (currentState.alertIndex + 1) % 3;
    render();
    if (alertActive) requestAnimationFrame(updateAlertScroll);
}

function toggleLayout() { setLayout(!layoutReversed); }

function findStopByQuery(rawQuery) {
    const query = rawQuery.trim().toLowerCase();
    if (!query) return null;
    return STOPS.find((stop) =>
        stop.stop_id.toLowerCase() === query ||
        stop.name.toLowerCase() === query ||
        `${stop.stop_id} - ${stop.name}`.toLowerCase() === query
    ) ?? null;
}

function getStationMatches(rawQuery) {
    const query = rawQuery.trim().toLowerCase();
    if (!query) return [];
    return STOPS.filter((stop) =>
        stop.stop_id.toLowerCase().includes(query) ||
        stop.name.toLowerCase().includes(query)
    ).slice(0, 8);
}

function hideStationSuggestions() {
    const box = document.getElementById('station-suggestions');
    if (!box) return;
    box.classList.add('hidden');
    box.innerHTML = '';
}

function updateLiveStationLabel() {
    const input = document.getElementById('station-search');
    if (!input) return;
    if (!liveStation) {
        input.value = '';
        return;
    }
    input.value = liveStation.name;
}

function updateStationSuggestions() {
    const input = document.getElementById('station-search');
    const box = document.getElementById('station-suggestions');
    if (!input || !box) return;
    const matches = getStationMatches(input.value);
    if (matches.length === 0) {
        hideStationSuggestions();
        return;
    }
    box.innerHTML = matches.map((stop) =>
        `<button type="button" class="station-suggestion" onclick="selectStationSuggestion('${stop.stop_id}')">${stop.name}</button>`
    ).join('');
    box.classList.remove('hidden');
}

async function selectStationSuggestion(stopId) {
    const match = STOPS.find((s) => s.stop_id === stopId);
    const input = document.getElementById('station-search');
    if (!match || !input) return;
    input.value = match.name;
    liveStation = match;
    liveDestination = null;
    updateLiveStationLabel();
    hideStationSuggestions();
    if (liveMode) {
        const ds1 = document.getElementById('destination-select');
        if (ds1) ds1.innerHTML = '<option value="">--</option>';
        await loadLiveCurrentStation();
    } else {
        populateDestinationDropdownStatic(match);
        randomiseWithStation();
    }
}

async function applyStationSearch() {
    const input = document.getElementById('station-search');
    if (!input) return;
    let match = findStopByQuery(input.value);
    if (!match) {
        const firstMatch = getStationMatches(input.value)[0];
        if (firstMatch) match = firstMatch;
    }
    if (!match) return;
    liveStation = match;
    liveDestination = null;
    updateLiveStationLabel();
    input.value = match.name;
    hideStationSuggestions();
    if (liveMode) {
        const ds2 = document.getElementById('destination-select');
        if (ds2) ds2.innerHTML = '<option value="">--</option>';
        await loadLiveCurrentStation();
    } else {
        populateDestinationDropdownStatic(match);
        randomiseWithStation();
    }
}

function handleStationSearchKeydown(event) {
    if (event.key !== 'Enter') return;
    event.preventDefault();
    applyStationSearch();
}

async function randomStation() {
    if (!Array.isArray(STOPS) || STOPS.length === 0) return;
    liveStation = STOPS[Math.floor(Math.random() * STOPS.length)];
    liveDestination = null;
    updateLiveStationLabel();
    if (liveMode) {
        const destSelect = document.getElementById('destination-select');
        if (destSelect) destSelect.innerHTML = '<option value="">--</option>';
        await loadLiveCurrentStation();
    } else {
        populateDestinationDropdownStatic(liveStation);
        randomiseWithStation();
    }
}

function disableLiveMode() {
    liveMode = false;
    const liveBtn = document.getElementById('btn-live');
    liveBtn.classList.remove('active');
    liveBtn.setAttribute('aria-pressed', 'false');
    if (liveIntervalId) {
        clearInterval(liveIntervalId);
        liveIntervalId = null;
    }
    liveStation = null;
    liveDestination = null;
    const destSelect = document.getElementById('destination-select');
    if (destSelect) destSelect.innerHTML = '<option value="">--</option>';
    updateLiveStationLabel();
    renderPage();
    randomise();
}

async function toggleLiveMode() {
    liveMode = !liveMode;
    const liveBtn = document.getElementById('btn-live');
    liveBtn.classList.toggle('active', liveMode);
    liveBtn.setAttribute('aria-pressed', liveMode ? 'true' : 'false');
    renderPage();
    if (liveMode) {
        if (!liveStation) {
            liveStation = STOPS[Math.floor(Math.random() * STOPS.length)];
        }
        updateLiveStationLabel();
        if (liveIntervalId) clearInterval(liveIntervalId);
        liveIntervalId = setInterval(() => { loadLiveCurrentStation(); }, 15000);
        await loadLiveCurrentStation();
        return;
    }
    disableLiveMode();
}

function getStaticDestinationsForStation(stop) {
    const seen = new Set();
    const dests = [];
    for (const line of (stop.lines ?? [])) {
        for (const d of (lineDestinations[line.name] ?? [])) {
            if (!seen.has(d)) { seen.add(d); dests.push(d); }
        }
    }
    return dests;
}

function populateDestinationDropdownStatic(stop) {
    const destSelect = document.getElementById('destination-select');
    if (!destSelect) return;
    const dests = getStaticDestinationsForStation(stop);
    destSelect.innerHTML = dests.length === 0
        ? '<option value="">--</option>'
        : dests.map(d => `<option value="${d}">${d}</option>`).join('');
    liveDestination = dests[0] ?? null;
}

function randomiseWithStation() {
    if (!liveStation) { randomise(true); return; }
    const lineName = liveDestination
        ? inferLineName(liveDestination, liveStation.lines?.[0]?.name)
        : (liveStation.lines?.[0]?.name ?? Object.keys(lineDestinations)[0]);
    const dests = lineDestinations[lineName] ?? [];
    const destination = liveDestination ?? dests[0] ?? 'Destino';
    const rand = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;
    const now = new Date();
    const next = rand(0, 39) / 4;
    currentState = {
        lineName,
        destination,
        clock: `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`,
        next,
        after1: next + rand(5, 10),
        after2: next + rand(10, 20),
        after3: next + rand(20, 30),
        alertIndex: rand(0, 2),
        carriageCapacities: randomCarriageCapacities(inferCarriageCount(lineName)),
    };
    render();
    requestAnimationFrame(updateAlertScroll);
}

function selectDestination(value) {
    if (!value) return;
    liveDestination = value;
    if (liveMode) {
        const selected = liveArrivals.find((a) => a.destination_name === value);
        if (selected) applyLiveArrival(selected);
    } else {
        currentState.destination = value;
        currentState.lineName = inferLineName(value, currentState.lineName);
        render();
    }
}

function updateAlertScroll() {
    document.querySelectorAll('.alert-strip.visible').forEach(strip => {
        const text = strip.querySelector('.alert-text');
        const bar = strip.querySelector('.alert-bar');
        const available = strip.clientWidth - bar.offsetWidth;

        const single = text.dataset.msg || text.textContent;
        text.textContent = single;
        const singleWidth = text.scrollWidth;

        if (singleWidth > available) {
            text.textContent = `${single}  •  ${single}`;
            const halfWidth = text.scrollWidth / 2;
            const duration = halfWidth / 80;
            text.style.setProperty('--marquee-from', '0px');
            text.style.setProperty('--marquee-to', `-${halfWidth}px`);
            text.style.animation = `marquee ${duration}s linear infinite`;
        } else {
            text.style.animation = 'none';
        }
    });
}

function getWaitParts(minutes) {
    const totalSeconds = Math.round(minutes * 60);
    return {
        minutes: Math.floor(totalSeconds / 60),
        seconds: String(totalSeconds % 60).padStart(2, '0'),
    };
}

function roundSecondsToQuarterMinutes(seconds) {
    const snapped = Math.round(Math.max(0, seconds) / 15) * 15;
    return snapped / 60;
}

function parseRawTimestamp(rawTimestamp) {
    if (!rawTimestamp || rawTimestamp.length !== 14) return new Date();
    const year = Number(rawTimestamp.slice(0, 4));
    const month = Number(rawTimestamp.slice(4, 6)) - 1;
    const day = Number(rawTimestamp.slice(6, 8));
    const hour = Number(rawTimestamp.slice(8, 10));
    const minute = Number(rawTimestamp.slice(10, 12));
    const second = Number(rawTimestamp.slice(12, 14));
    return new Date(year, month, day, hour, minute, second);
}

function renderWaitTime(el, minutes) {
    const { minutes: wholeMinutes, seconds } = getWaitParts(minutes);
    el.innerHTML = `<span class="wait-minutes">${wholeMinutes}</span><span class="wait-seconds">${seconds}</span>`;
}

function formatWholeWaitTime(minutes) {
    return String(Math.floor(minutes));
}

function triggerMinuteBlink(el, displayedMinute) {
    const prevMinute = Number(el.dataset.prevMinute);
    if (!Number.isNaN(prevMinute) && prevMinute !== displayedMinute) {
        el.classList.remove('minute-change-blink');
        void el.offsetWidth;
        el.classList.add('minute-change-blink');
    }
    el.dataset.prevMinute = String(displayedMinute);
}

function inferCarriageCount(lineName) {
    return lineName === 'Linha Amarela' ? 3 : 6;
}

// carriageCapacities: ('empty' | 'half' | 'full')[]
// When real API data is available, pass the mapped array directly instead of randomising.
const CAPACITY_STATES = ['empty', 'half', 'full'];

function randomCarriageCapacities(count) {
    return Array.from({ length: count }, () =>
        CAPACITY_STATES[Math.floor(Math.random() * CAPACITY_STATES.length)]
    );
}

function renderCapacityHeads(el, carriageCapacities) {
    el.innerHTML = carriageCapacities.map(state =>
        `<span class="capacity-carriage ${state}"></span>`
    ).join('');
}

const lineNames_en = {
    'Linha Vermelha': 'Red Line',
    'Linha Verde':    'Green Line',
    'Linha Amarela':  'Yellow Line',
    'Linha Azul':     'Blue Line',
};

const lineColors = {
    'Linha Vermelha': '#E6196E',
    'Linha Verde':    '#00A0A5',
    'Linha Amarela':  '#FAB914',
    'Linha Azul':     '#5082C3',
};

const lineDestinations = {
    'Linha Vermelha': ['Aeroporto', 'São Sebastião'],
    'Linha Verde':    ['Telheiras', 'Cais do Sodré'],
    'Linha Amarela':  ['Odivelas', 'Rato'],
    'Linha Azul':     ['Reboleira', 'Santa Apolónia'],
};

const lineLogos = {
    'Linha Vermelha': '/red-line-logo.svg',
    'Linha Verde':    '/green-line-logo.svg',
    'Linha Amarela':  '/yellow-line-logo.svg',
    'Linha Azul':     '/blue-line-logo.svg',
};

function getDepFontSizes(count) {
    if (count === 1) return { dest:192, time:160, logo:88 };
    if (count === 2) return { dest:128, time:108, logo:72 };
    if (count <= 4)  return { dest:96,  time:80,  logo:56 };
    if (count <= 6)  return { dest:68,  time:58,  logo:42 };
    return                  { dest:52,  time:44,  logo:32 };
}

function getStationDeps(stop) {
    const deps = [];
    for (const line of (stop.lines ?? [])) {
        for (const dest of (lineDestinations[line.name] ?? [])) {
            deps.push({ destination: dest, lineName: line.name });
        }
    }
    return deps;
}

function renderLineBar(station) {
    const el = document.getElementById('hs-line-bar');
    if (!el) return;
    const lines = station?.lines ?? [];
    el.innerHTML = (lines.length ? lines : [{name:'Linha Azul'}]).map(l =>
        `<div class="hs-line-bar-seg" style="background:${lineColors[l.name] ?? '#5082C3'}"></div>`
    ).join('');
}

let hsInfoIndex = 0;
let hsInfoTimerId = null;

function renderHall(deps) {
    const count = deps.length;
    const fs = getDepFontSizes(count);
    const t = i18n[currentLang];
    const dept = document.getElementById('hs-departures');
    if (!dept) return;
    dept.innerHTML = deps.map((dep, di) => {
        const color = lineColors[dep.lineName] ?? '#5082C3';
        const logo  = lineLogos[dep.lineName]  ?? '/blue-line-logo.svg';
        const seed  = dep.destination.charCodeAt(0) * 3 + dep.destination.length * 7 + di * 11;
        const t1 = ((seed * 13 + 7)  % 12) + 1;
        const t2 = t1 + ((seed * 5 + 3)  % 7) + 4;
        const t3 = t2 + ((seed * 3 + 11) % 7) + 4;
        const times = [t1, t2, t3];
        const timeCols = times.map((m) => {
            const isNow = m < 1;
            return `<div class="hs-time-col${isNow ? ' hs-now' : ''}">
                <span class="hs-time-val" style="font-size:${fs.time}px">${isNow ? t.hallNow : m}</span>
                ${!isNow ? `<span class="hs-time-unit">${t.min}</span>` : ''}
            </div>`;
        }).join('');
        return `<div class="hs-row" style="--row-color:${color}">
            <img src="${logo}" class="hs-row-logo" style="height:${fs.logo}px" alt="${dep.lineName}">
            <span class="hs-dest" style="font-size:${fs.dest}px">${dep.destination.toUpperCase()}</span>
            <div class="hs-times">${timeCols}</div>
        </div>`;
    }).join('');
}

function renderHallClock() {
    const now = new Date();
    const hh  = String(now.getHours()).padStart(2, '0');
    const mm  = String(now.getMinutes()).padStart(2, '0');
    const el  = document.getElementById('hs-clock');
    if (el) el.textContent = `${hh}:${mm}`;
    const dateEl = document.getElementById('hs-date');
    if (dateEl) {
        const t = i18n[currentLang];
        const weekdays = currentLang === 'en'
            ? ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday']
            : ['Domingo','Segunda','Terça','Quarta','Quinta','Sexta','Sábado'];
        const months = currentLang === 'en'
            ? ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
            : ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
        dateEl.textContent = `${weekdays[now.getDay()]} · ${now.getDate()} ${months[now.getMonth()]} ${now.getFullYear()}`;
    }
}

function startHallInfoRotation() {
    const msgs = i18n[currentLang].hallInfoMessages;
    const el   = document.getElementById('hs-info-msg');
    if (!el || !msgs.length) return;
    if (hsInfoTimerId) clearInterval(hsInfoTimerId);
    el.classList.remove('fading');
    el.textContent = msgs[hsInfoIndex % msgs.length];
    hsInfoTimerId = setInterval(() => {
        el.classList.add('fading');
        setTimeout(() => {
            hsInfoIndex = (hsInfoIndex + 1) % msgs.length;
            el.textContent = msgs[hsInfoIndex];
            el.classList.remove('fading');
        }, 600);
    }, 8000);
}

function renderHallScreen() {
    const station = liveStation ?? STOPS.find(s => s.stop_id === 'AM') ?? STOPS[0];
    const stNameEl = document.getElementById('hs-station-name');
    if (stNameEl) stNameEl.textContent = (station.name ?? '').toUpperCase();
