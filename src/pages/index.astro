function render() {
    const t = i18n[currentLang];
    const { lineName, destination, clock, next, after1, after2, after3, alertIndex, carriageCapacities } = currentState;
    const displayLine = currentLang === 'en' ? lineNames_en[lineName] : lineName;
    document.querySelectorAll('.panel').forEach(el => el.style.setProperty('--line-color', lineColors[lineName]));
    document.querySelectorAll('.label').forEach(el => el.textContent = `${displayLine} · ${t.direction}`);
    document.querySelectorAll('.destination').forEach(el => el.textContent = destination);
    document.querySelectorAll('.clock').forEach(el => el.textContent = clock);
    document.querySelectorAll('.time-value').forEach(el => {
        if (next < 3) {
            renderWaitTime(el, next);
            triggerMinuteBlink(el, getWaitParts(next).minutes);
        } else {
            el.textContent = formatWholeWaitTime(next);
            triggerMinuteBlink(el, Math.ceil(next));
        }
    });
    document.querySelectorAll('.time-block').forEach(el => el.classList.toggle('blink', next < 1));
    document.querySelectorAll('.time-unit').forEach(el => el.textContent = t.min);
    document.querySelectorAll('.after-unit').forEach(el => el.textContent = t.min);
    document.querySelectorAll('.capacity-heads').forEach(el => renderCapacityHeads(el, carriageCapacities));
    document.querySelectorAll('.alert-strip').forEach(el => el.classList.toggle('visible', alertActive));
