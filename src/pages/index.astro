function inferLineName(destinationName, fallbackLineName) {
    for (const [lineName, destinations] of Object.entries(lineDestinations)) {
        if (destinations.includes(destinationName)) return lineName;
    }
    return fallbackLineName ?? 'Linha Azul';
}

