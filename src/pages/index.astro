}

async function loadLiveCurrentStation() {
    if (!liveStation) {
        if (!Array.isArray(STOPS) || STOPS.length === 0) return;
        liveStation = STOPS[Math.floor(Math.random() * STOPS.length)];
    }
    let response;
    try {
        response = await fetch(`${LIVE_API_BASE}${encodeURIComponent(liveStation.stop_id)}`);
    } catch (networkError) {
        console.warn('Live mode: API unreachable.', networkError);
        disableLiveMode();
        return;
    }
    if (!response.ok) {
        console.warn(`Live mode: API returned HTTP ${response.status}.`);
        disableLiveMode();
        return;
    }
    try {
        const data = await response.json();
        const arrivals = Array.isArray(data.arrivals) ? data.arrivals : [];
        const validArrivals = arrivals.filter((a) => Array.isArray(a.times) && a.times.length > 0);
        if (validArrivals.length === 0) throw new Error('No valid arrivals');
        liveArrivals = validArrivals;

        let selected = liveDestination
            ? validArrivals.find((a) => a.destination_name === liveDestination) ?? null
            : null;
        if (!selected) {
            selected = validArrivals[Math.floor(Math.random() * validArrivals.length)];
            liveDestination = selected.destination_name;
        }

        updateDestinationDropdown(validArrivals);
        applyLiveArrival(selected);
    } catch (error) {
        console.warn('Live mode fetch failed for current station.', error);
    }
}

function updateDestinationDropdown(arrivals) {
    const destSelect = document.getElementById('destination-select');
    if (!destSelect) return;
    const destinations = arrivals.map((a) => a.destination_name).filter(Boolean);
    if (destinations.length === 0) {
        destSelect.innerHTML = '<option value="">--</option>';
        return;
    }
    destSelect.innerHTML = destinations
        .map((d) => `<option value="${d}"${d === liveDestination ? ' selected' : ''}>${d}</option>`)
        .join('');
}

function applyLiveArrival(selected) {
    const fallbackLineName = liveStation?.lines?.[0]?.name ?? 'Linha Azul';
    const times = [...selected.times].sort((a, b) => a.arrival_seconds - b.arrival_seconds);
    const next = roundSecondsToQuarterMinutes(times[0].arrival_seconds);
    const after1 = times[1] ? roundSecondsToQuarterMinutes(times[1].arrival_seconds) : next + 6;
    const after2 = times[2] ? roundSecondsToQuarterMinutes(times[2].arrival_seconds) : after1 + 6;
    const after3 = after2 + 7;
    const timestamp = parseRawTimestamp(selected.raw_timestamp);
    const destination = selected.destination_name || 'Destino';
    const lineName = inferLineName(destination, fallbackLineName);
    const nextTrainKey = times[0].train_id ?? `${destination}:${times[0].arrival_seconds}`;
    const carriageCount = inferCarriageCount(lineName);
    const sameTrainAsBefore = nextTrainKey === lastNextTrainKey
        && currentState.carriageCapacities?.length === carriageCount;
    const carriageCapacities = sameTrainAsBefore
        ? currentState.carriageCapacities
        : randomCarriageCapacities(carriageCount);
    lastNextTrainKey = nextTrainKey;

    currentState = {
        lineName,
        destination,
        clock: `${String(timestamp.getHours()).padStart(2, '0')}:${String(timestamp.getMinutes()).padStart(2, '0')}`,
        next,
        after1,
        after2,
        after3,
        alertIndex: Math.floor(Math.random() * 3),
        carriageCapacities,
    };

    render();
    if (alertActive) requestAnimationFrame(updateAlertScroll);
}


