.hs-row { display:flex; align-items:center; flex:1; border-left:14px solid var(--row-color,rgba(255,255,255,.3)); border-bottom:1px solid rgba(255,255,255,.08); padding:0 56px 0 40px; gap:28px; min-height:0; }
