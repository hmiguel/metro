        ],
    },
};

function render() {
    const t = i18n[currentLang];
    const { lineName, destination, clock, next, after1, after2, after3, alertIndex, capacityLevel } = currentState;
    const displayLine = currentLang === 'en' ? lineNames_en[lineName] : lineName;
    document.querySelectorAll('.panel').forEach(el => el.style.setProperty('--line-color', lineColors[lineName]));
    document.querySelectorAll('.label').forEach(el => el.textContent = `${displayLine} · ${t.direction}`);
    document.querySelectorAll('.destination').forEach(el => el.textContent = destination);
    document.querySelectorAll('.clock').forEach(el => el.textContent = clock);
    document.querySelectorAll('.time-value').forEach(el => {
        if (next < 3) {
            renderWaitTime(el, next);
            triggerMinuteBlink(el, getWaitParts(next).minutes);
        } else {
            el.textContent = formatWholeWaitTime(next);
            triggerMinuteBlink(el, Math.ceil(next));
        }
    });
    document.querySelectorAll('.time-block').forEach(el => el.classList.toggle('blink', next < 1));
    document.querySelectorAll('.time-unit').forEach(el => el.textContent = t.min);
    document.querySelectorAll('.after-unit').forEach(el => el.textContent = t.min);
    document.querySelectorAll('.capacity-heads').forEach(el => renderCapacityHeads(el, capacityLevel));
    document.querySelectorAll('.alert-strip').forEach(el => el.classList.toggle('visible', alertActive));
    document.querySelectorAll('.alert-text').forEach(el => {
        const msg = t.alerts(displayLine)[alertIndex];
        el.textContent = msg;
        el.dataset.msg = msg;
        el.style.animation = 'none';
    });
    const afterValues = document.querySelectorAll('.after-value');
    for (let i = 0; i < afterValues.length; i += 2) {
        afterValues[i].textContent = formatWholeWaitTime(after1);
        triggerMinuteBlink(afterValues[i], Math.ceil(after1));

        afterValues[i + 1].textContent = formatWholeWaitTime(after2);
        triggerMinuteBlink(afterValues[i + 1], Math.ceil(after2));

        if (afterValues[i + 2]) {
            afterValues[i + 2].textContent = formatWholeWaitTime(after3);
            triggerMinuteBlink(afterValues[i + 2], Math.ceil(after3));
        }
    }
}

async function loadLiveCurrentStation() {
    try {
        if (!liveStation) {
            if (!Array.isArray(STOPS) || STOPS.length === 0) throw new Error('No stops available');
            liveStation = STOPS[Math.floor(Math.random() * STOPS.length)];
        }
        const fallbackLineName = liveStation.lines?.[0]?.name ?? 'Linha Azul';
        const response = await fetch(`${LIVE_API_BASE}${encodeURIComponent(liveStation.stop_id)}`);
        if (!response.ok) throw new Error(`HTTP ${response.status}`);

        const data = await response.json();
        const arrivals = Array.isArray(data.arrivals) ? data.arrivals : [];
        const validArrivals = arrivals.filter((a) => Array.isArray(a.times) && a.times.length > 0);
        if (validArrivals.length === 0) throw new Error('No valid arrivals');
        liveArrivals = validArrivals;

        let selected = liveDestination
            ? validArrivals.find((a) => a.destination_name === liveDestination) ?? null
            : null;
        if (!selected) {
            selected = validArrivals[Math.floor(Math.random() * validArrivals.length)];
            liveDestination = selected.destination_name;
        }

        updateDestinationDropdown(validArrivals);
        applyLiveArrival(selected);
    } catch (error) {
        console.warn('Live mode fetch failed for current station.', error);
    }
}

function updateDestinationDropdown(arrivals) {
    const destSelect = document.getElementById('destination-select');
    if (!destSelect) return;
    const destinations = arrivals.map((a) => a.destination_name).filter(Boolean);
    if (destinations.length === 0) {
        destSelect.innerHTML = '<option value="">--</option>';
        return;
    }
    destSelect.innerHTML = destinations
        .map((d) => `<option value="${d}"${d === liveDestination ? ' selected' : ''}>${d}</option>`)
        .join('');
}

function applyLiveArrival(selected) {
    const fallbackLineName = liveStation?.lines?.[0]?.name ?? 'Linha Azul';
    const times = [...selected.times].sort((a, b) => a.arrival_seconds - b.arrival_seconds);
    const next = roundSecondsToQuarterMinutes(times[0].arrival_seconds);
    const after1 = times[1] ? roundSecondsToQuarterMinutes(times[1].arrival_seconds) : next + 6;
    const after2 = times[2] ? roundSecondsToQuarterMinutes(times[2].arrival_seconds) : after1 + 6;
    const after3 = after2 + 7;
    const timestamp = parseRawTimestamp(selected.raw_timestamp);
    const destination = selected.destination_name || 'Destino';
    const lineName = inferLineName(destination, fallbackLineName);
    const nextTrainKey = times[0].train_id ?? `${destination}:${times[0].arrival_seconds}`;
    const capacityLevels = ['low', 'medium', 'high'];
    const capacityLevel = nextTrainKey !== lastNextTrainKey
        ? capacityLevels[Math.floor(Math.random() * capacityLevels.length)]
        : (currentState.capacityLevel ?? capacityLevels[0]);
    lastNextTrainKey = nextTrainKey;

    currentState = {
        lineName,
        destination,
        clock: `${String(timestamp.getHours()).padStart(2, '0')}:${String(timestamp.getMinutes()).padStart(2, '0')}`,
        next,
        after1,
        after2,
        after3,
        alertIndex: Math.floor(Math.random() * 3),
        capacityLevel,
    };

    render();
    if (alertActive) requestAnimationFrame(updateAlertScroll);
}


