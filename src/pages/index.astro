function renderPage() {
    const s = pageStrings[currentLang];
    const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
    set('txt-title',          s.title);
    set('txt-station-label',  s.stationLabel);
    set('txt-dest-label',     s.destLabel);
    set('txt-alert-label',    s.alertLabel);
    set('txt-lang-label',     s.langLabel);
    set('txt-layout-label',   s.layoutLabel);
    set('txt-panel-label',    s.panelLabel);
    set('txt-options-section', s.optionsSection);
    set('txt-layout-right',   s.layoutRight);
    set('txt-layout-left',    s.layoutLeft);
    set('txt-footer',         liveMode ? s.footerLive : s.footer);
    const setHTML = (id, val) => { const el = document.getElementById(id); if (el) el.innerHTML = val; };
    setHTML('txt-about-p1', s.aboutP1);
    setHTML('txt-about-p2', s.aboutP2);
    const stationSearch = document.getElementById('station-search');
    if (stationSearch) stationSearch.placeholder = s.stationPlaceholder;
    document.querySelectorAll('.preview-label').forEach((el, i) => el.textContent = s.previewLabels[i]);
    const panelSel = document.getElementById('panel-select');
    if (panelSel) {
        const opts = panelSel.querySelectorAll('option');
        s.panelOptions.forEach((label, i) => { if (opts[i]) opts[i].textContent = label; });
    }
}
const THEME_SVG_SUN = `<svg aria-hidden="true" focusable="false" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path stroke-linecap="round" d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>`;
const THEME_SVG_MOON = `<svg aria-hidden="true" focusable="false" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>`;


function toggleTheme() {
    currentTheme = currentTheme === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = currentTheme === 'light' ? 'light' : '';
    const btn = document.getElementById('btn-theme');
    if (btn) btn.innerHTML = currentTheme === 'dark' ? THEME_SVG_SUN : THEME_SVG_MOON;
    try { localStorage.setItem('metro-theme', currentTheme); } catch {}
}

function toggleLang() { setLang(currentLang === 'pt' ? 'en' : 'pt'); }

function randomise(forceOffline = false) {
    if (liveMode && !forceOffline) {
        loadLiveCurrentStation();
        return;
    }
    const rand = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;

    const lineNames = Object.keys(lineDestinations);
    const lineName = lineNames[rand(0, lineNames.length - 1)];
    const stations = lineDestinations[lineName];
    const capacityLevels = ['low', 'medium', 'high'];

    const now = new Date();
    const next = rand(0, 39) / 4;

    currentState = {
        lineName,
        destination: stations[rand(0, stations.length - 1)],
        clock: `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`,
        next,
        after1: next + rand(5, 10),
        after2: next + rand(10, 20),
        after3: next + rand(20, 30),
        alertIndex: rand(0, 2),
        capacityLevel: capacityLevels[rand(0, capacityLevels.length - 1)],
    };

    if (!alertActive && Math.random() < 0.3) setAlert(true);
    render();
    requestAnimationFrame(updateAlertScroll);
}

