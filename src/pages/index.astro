function randomise(forceOffline = false) {
    if (liveMode && !forceOffline) {
        loadLiveCurrentStation();
        return;
    }
    const rand = (min, max) => Math.floor(Math.random() * (max - min + 1)) + min;

    const lineNames = Object.keys(lineDestinations);
    const lineName = lineNames[rand(0, lineNames.length - 1)];
    const stations = lineDestinations[lineName];

    const now = new Date();
    const next = rand(0, 39) / 4;

    currentState = {
        lineName,
        destination: stations[rand(0, stations.length - 1)],
        clock: `${String(now.getHours()).padStart(2, '0')}:${String(now.getMinutes()).padStart(2, '0')}`,
        next,
        after1: next + rand(5, 10),
        after2: next + rand(10, 20),
        after3: next + rand(20, 30),
        alertIndex: rand(0, 2),
        carriageCapacities: randomCarriageCapacities(inferCarriageCount(lineName)),
    };

    if (!alertActive && Math.random() < 0.3) setAlert(true);
    render();
    requestAnimationFrame(updateAlertScroll);
}

// ── Context / In-situ View ───────────────────────────────
let contextOpen = false;
let contextZoom  = 1;

function applyContextZoom(direction) {
    contextZoom = Math.max(0.2, Math.min(4, contextZoom * (direction > 0 ? 1.1 : 1 / 1.1)));
    const slot  = document.getElementById('context-panel-slot');
    const scene = document.querySelector('.context-scene');
    if (!slot || !scene) return;
    const baseW = scene.offsetWidth * 0.38;
    const newW  = Math.round(baseW * contextZoom);
    slot.style.width = newW + 'px';
    scaleContextFrame(slot, newW);
}

function scaleContextFrame(slot, slotW) {
    const cloned = slot.querySelector('.panel-frame');
    if (!cloned || currentPanelType === 'hall') return;
    const nativeW = PANEL_SIZES[currentPanelType].w + 32;
    const nativeH = PANEL_SIZES[currentPanelType].h + 38;
    const s = slotW / nativeW;
    cloned.style.transform       = `scale(${s})`;
    cloned.style.transformOrigin = 'top left';
    cloned.style.marginRight     = `${-Math.round(nativeW * (1 - s))}px`;
    cloned.style.marginBottom    = `${-Math.round(nativeH * (1 - s))}px`;
}

function refreshContextPanel() {
    if (!contextOpen || currentPanelType === 'hall') return;
    const slot = document.getElementById('context-panel-slot');
    if (!slot) return;
    const activePreview = document.querySelector('.preview-item.visible');
    if (!activePreview) return;
    const frame = activePreview.querySelector('.panel-frame');
    if (!frame) return;

    const slotW = slot.offsetWidth || Math.round(document.querySelector('.context-scene')?.offsetWidth * 0.32) || 300;
    const cloned = frame.cloneNode(true);
    cloned.id = '';
    cloned.style.transform = cloned.style.transformOrigin = cloned.style.marginRight = cloned.style.marginBottom = '';
    slot.innerHTML = '';
    slot.appendChild(cloned);
    scaleContextFrame(slot, slotW);
}

function openContextView() {
    if (currentPanelType === 'hall') return;
    const inline = document.getElementById('context-inline');
    const slot   = document.getElementById('context-panel-slot');
    if (!inline || !slot) return;

    if (contextOpen) {
        // toggle off
        contextOpen = false;
        inline.classList.remove('visible');
        document.getElementById('btn-context').classList.remove('active');
        if (inline._cleanup) { inline._cleanup(); inline._cleanup = null; }
        return;
    }

    contextOpen = true;
    contextZoom  = 1;
    slot.style.left = slot.style.top = slot.style.width = '';
    inline.classList.add('visible');
    document.getElementById('btn-context').classList.add('active');

    requestAnimationFrame(() => {
        refreshContextPanel();

        // Drag
        let dragging = false, ox = 0, oy = 0;
        function onDown(e) {
            e.preventDefault(); e.stopPropagation();
            dragging = true;
            const pt = e.touches ? e.touches[0] : e;
            ox = pt.clientX - slot.offsetLeft;
            oy = pt.clientY - slot.offsetTop;
            slot.classList.add('dragging');
        }
        function onMove(e) {
            if (!dragging) return;
            const pt = e.touches ? e.touches[0] : e;
            slot.style.left = `${pt.clientX - ox}px`;
            slot.style.top  = `${pt.clientY - oy}px`;
        }
        function onUp() { dragging = false; slot.classList.remove('dragging'); }

        slot.addEventListener('mousedown',  onDown);
        slot.addEventListener('touchstart', onDown, { passive: false });
        window.addEventListener('mousemove', onMove);
        window.addEventListener('touchmove', onMove, { passive: false });
        window.addEventListener('mouseup',  onUp);
        window.addEventListener('touchend', onUp);

        // Scroll-wheel zoom
        function onWheel(e) { e.preventDefault(); applyContextZoom(-Math.sign(e.deltaY)); }
        inline.addEventListener('wheel', onWheel, { passive: false });

        // Pinch-to-zoom
        let lastPinchDist = null;
        function onTouchZoom(e) {
            if (e.touches.length !== 2) { lastPinchDist = null; return; }
            const dist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
            if (lastPinchDist !== null) applyContextZoom(dist > lastPinchDist ? 1 : -1);
            lastPinchDist = dist;
        }
        inline.addEventListener('touchmove', onTouchZoom, { passive: false });

        inline._cleanup = () => {
            slot.removeEventListener('mousedown',  onDown);
            slot.removeEventListener('touchstart', onDown);
            window.removeEventListener('mousemove', onMove);
            window.removeEventListener('touchmove', onMove);
            window.removeEventListener('mouseup',  onUp);
            window.removeEventListener('touchend', onUp);
            inline.removeEventListener('wheel',     onWheel);
            inline.removeEventListener('touchmove', onTouchZoom);
        };
    });
}

